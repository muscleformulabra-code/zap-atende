# Copie este arquivo para ".env" (sem .example) e preencha com os dados do seu Supabase.
# Onde achar: painel do Supabase > Project Settings > API

SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Use a chave "service_role" (secreta) — NÃO a anon. Fica na mesma tela de API.
SUPABASE_SERVICE_KEY=cole-aqui-a-service-role-key

# Onde o painel (cérebro do chatbot) está rodando. Local = http://localhost:3000
PAINEL_URL=http://localhost:3000
